{
  "name": "opencode-qwen-oauth",
  "version": "0.1.0",
  "description": "OpenCode plugin for Qwen/Alibaba Cloud OAuth authentication (device code + PKCE) — no API key needed",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": "aikerary",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aikerary/opencode-qwen-oauth.git"
  },
  "homepage": "https://github.com/aikerary/opencode-qwen-oauth#readme",
  "bugs": {
    "url": "https://github.com/aikerary/opencode-qwen-oauth/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "qwen",
    "alibaba",
    "alibaba-cloud",
    "dashscope",
    "oauth",
    "oauth2",
    "pkce",
    "device-code",
    "plugin",
    "ai",
    "llm",
    "typescript",
    "bun"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": "*"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "*",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
